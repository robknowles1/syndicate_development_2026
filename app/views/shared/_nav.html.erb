<div data-controller="nav">
  <nav class="fixed top-0 left-0 right-0 h-[70px] bg-[#242121] flex items-center justify-between px-4" style="z-index:999">
    <%# Logo — left side %>
    <%= link_to root_path, class: "flex items-center" do %>
      <%= image_tag "syndicate-lion.png", alt: t("nav.logo_alt"), class: "h-[50px] w-auto" %>
    <% end %>

    <%# Desktop nav links — hidden on mobile, flex on md+ %>
    <div class="hidden md:flex items-center space-x-6">
      <%= link_to t("nav.home"), root_path, class: "text-white font-bold tracking-wide hover:text-red-600 transition-colors" %>
      <%= link_to t("nav.about"), about_path, class: "text-white font-bold tracking-wide hover:text-red-600 transition-colors" %>
      <%= link_to t("nav.gallery"), gallery_path, class: "text-white font-bold tracking-wide hover:text-red-600 transition-colors" %>
      <% if SiteSetting.enabled?("services_page_published") %>
        <%= link_to t("nav.services"), services_path,
              class: "font-bold tracking-wide transition-colors #{current_page?(services_path) ? 'text-red-600' : 'text-white hover:text-red-600'}" %>
      <% end %>
    </div>

    <%# Mobile hamburger button — visible on mobile, hidden on md+ %>
    <button class="block md:hidden text-white focus:outline-none"
            data-action="click->nav#toggle"
            aria-label="<%= t('nav.toggle_aria_label') %>">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <%# Mobile dropdown menu — positioned below the fixed nav bar %>
  <div class="hidden fixed top-[70px] left-0 right-0 bg-[#242121] border-t-4 border-red-600 md:hidden" style="z-index:998"
       data-nav-target="menu">
    <div class="flex flex-col py-2">
      <%= link_to t("nav.home"), root_path,
            class: "text-white font-bold px-6 py-3 hover:text-red-600 transition-colors",
            data: { action: "click->nav#toggle" } %>
      <%= link_to t("nav.about"), about_path,
            class: "text-white font-bold px-6 py-3 hover:text-red-600 transition-colors",
            data: { action: "click->nav#toggle" } %>
      <%= link_to t("nav.gallery"), gallery_path,
            class: "text-white font-bold px-6 py-3 hover:text-red-600 transition-colors",
            data: { action: "click->nav#toggle" } %>
      <% if SiteSetting.enabled?("services_page_published") %>
        <%= link_to t("nav.services"), services_path,
              class: "font-bold px-6 py-3 transition-colors #{current_page?(services_path) ? 'text-red-600' : 'text-white hover:text-red-600'}",
              data: { action: "click->nav#toggle" } %>
      <% end %>
    </div>
  </div>
</div>
