<h1 class="text-2xl font-bold mb-8"><%= t("admin.services_page.heading") %></h1>

<%# ---- Published toggle ---- %>
<section class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-lg font-semibold mb-4">Visibility</h2>
  <%= form_with url: admin_services_page_path, method: :patch, html: { id: "toggle-form" } do |f| %>
    <%# Hidden field ensures "false" is sent when checkbox is unchecked %>
    <input type="hidden" name="published" value="false">
    <label class="flex items-center gap-3 cursor-pointer">
      <input type="checkbox" name="published" value="true" <%= "checked" if @published %>
             class="w-5 h-5 accent-red-600">
      <span class="font-semibold"><%= t("admin.services_page.published_label") %></span>
    </label>
    <p class="text-sm text-gray-500 mt-2">
      Current status: <strong><%= @published ? "Published" : "Unpublished" %></strong>
    </p>
    <%= submit_tag t("admin.services_page.save"), class: "mt-4 bg-red-600 text-white font-bold py-2 px-5 rounded hover:bg-red-700 cursor-pointer" %>
  <% end %>
</section>

<%# ---- Content editor ---- %>
<section class="bg-white rounded-lg shadow p-6" data-controller="bullet-editor">
  <%= form_with url: admin_services_page_path, method: :patch, html: { id: "content-form" } do |f| %>
    <% @sections.each do |section| %>
      <div class="mb-8 border-b pb-6 last:border-b-0 last:pb-0">
        <h2 class="text-lg font-bold mb-4"><%= section.heading %></h2>

        <div class="mb-4">
          <%= label_tag "service_sections[#{section.slug}][heading]", "Heading", class: "block text-sm font-semibold mb-1" %>
          <%= text_field_tag "service_sections[#{section.slug}][heading]", section.heading,
                class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-600" %>
        </div>

        <div class="mb-3">
          <span class="block text-sm font-semibold mb-2">Bullet Items</span>
          <div id="bullets-<%= section.slug %>" class="space-y-2">
            <% section.service_bullets.each_with_index do |bullet, idx| %>
              <div class="flex items-center gap-2 bullet-row">
                <%= hidden_field_tag "service_sections[#{section.slug}][service_bullets_attributes][#{idx}][id]", bullet.id %>
                <%= hidden_field_tag "service_sections[#{section.slug}][service_bullets_attributes][#{idx}][position]", bullet.position %>
                <%= text_field_tag "service_sections[#{section.slug}][service_bullets_attributes][#{idx}][body]", bullet.body,
                      class: "flex-1 border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-600" %>
                <label class="flex items-center gap-1 text-sm text-gray-600 whitespace-nowrap">
                  <%= check_box_tag "service_sections[#{section.slug}][service_bullets_attributes][#{idx}][_destroy]",
                        "1", false, class: "accent-red-600" %>
                  Remove
                </label>
              </div>
            <% end %>
          </div>

          <%# New bullet template — hidden, cloned by Stimulus %>
          <template id="new-bullet-template-<%= section.slug %>">
            <div class="flex items-center gap-2 bullet-row">
              <input type="hidden" name="service_sections[SLUG][service_bullets_attributes][NEW_INDEX][position]" value="NEW_POS">
              <input type="text" name="service_sections[SLUG][service_bullets_attributes][NEW_INDEX][body]" value=""
                     class="flex-1 border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-600">
              <label class="flex items-center gap-1 text-sm text-gray-600 whitespace-nowrap">
                <input type="checkbox" name="service_sections[SLUG][service_bullets_attributes][NEW_INDEX][_destroy]"
                       value="1" class="accent-red-600">
                Remove
              </label>
            </div>
          </template>

          <button type="button"
                  class="mt-2 text-sm text-red-600 hover:text-red-800 font-semibold"
                  data-action="click->bullet-editor#addBullet"
                  data-bullet-editor-section-slug-param="<%= section.slug %>">
            + Add bullet
          </button>
        </div>
      </div>
    <% end %>

    <%= submit_tag t("admin.services_page.save"),
          class: "mt-4 bg-red-600 text-white font-bold py-2 px-5 rounded hover:bg-red-700 cursor-pointer" %>
  <% end %>
</section>
